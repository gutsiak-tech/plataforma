# Postgres (host-side tools). In Docker services, core-api/tegola force POSTGRES_HOST=postgis.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=plataforma
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Loader paths used by docker compose run core-api ... (must be container-visible paths)
PATH_SHAPE_MUNICIPIOS=/workspace/data-lake/bronze/geodata/municipios/uf=PR/ano=2024
PATH_MAPPED_CSV=/workspace/data-lake/prata/dados_mapeados.csv
# Two-letter UF code used by loader filter
DEFAULT_UF=PR
